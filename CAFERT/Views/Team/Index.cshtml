@model List<CAFERT.Models.TeamMember>
@{
    ViewData["Title"] = "Our Team";
}

<!-- Team Header -->
<section class="team-header-section">
    <div class="container">
        <span class="hero-subtitle" style="color: var(--caramel);">PEOPLE BEHIND THE FLAVORS</span>
        <h1 class="serif-font">Meet Our Team</h1>
        <p class="mb-0">The culinary experts, coffee artisans, and friendly faces of CAFERT.</p>
    </div>
</section>

<!-- Team Cards Grid -->
<section class="py-5">
    <div class="container py-4">
        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var member in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="team-card">
                            <div class="team-img-wrapper">
                                @if (!string.IsNullOrEmpty(member.PhotoUrl))
                                {
                                    <img src="@member.PhotoUrl" alt="@member.Name" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 bg-secondary d-flex align-items-center justify-content-center text-white" style="font-size: 3rem;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                }
                            </div>
                            <div class="team-info">
                                <h3 class="team-name">@member.Name</h3>
                                <p class="team-role">@member.Role</p>
                                <p class="team-bio">@member.Bio</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size: 3rem; color: var(--muted);"></i>
                <h3 class="serif-font mt-3">No team members loaded</h3>
                <p class="text-muted">Check back later or add staff members in the admin panel.</p>
                <a asp-controller="Dashboard" asp-action="TeamMembers" class="btn-cafert-caramel mt-2">
                    Go to Dashboard
                </a>
            </div>
        }
    </div>
</section>
