@model CAFERT.Controllers.LoginSuccessViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logging in...</title>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #2d2218;
            color: #fbf8f3;
            font-family: 'Jost', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .loader-container {
            text-align: center;
            padding: 30px;
        }
        .spinner {
            border: 4px solid rgba(212,168,90,.18);
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border-left-color: #d4a85a;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        h2 {
            font-weight: 500;
            margin-bottom: 8px;
        }
        p {
            color: #9e8d75;
            font-size: 0.95rem;
            margin: 0;
        }
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="loader-container">
        <div class="spinner"></div>
        <h2>Welcome back!</h2>
        <p>Opening admin panel in a new tab...</p>
    </div>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Open the target dashboard URL in a new tab
            var adminWindow = window.open('@Model.TargetUrl', '_blank');
            
            // If the browser blocked the popup, redirect the current tab instead to ensure it works
            if (!adminWindow || adminWindow.closed || typeof adminWindow.closed == 'undefined') {
                window.location.href = '@Model.TargetUrl';
            } else {
                // Otherwise, redirect the current tab back to the storefront (or wherever it was)
                window.location.href = '@Model.CurrentUrl';
            }
        });
    </script>
</body>
</html>
