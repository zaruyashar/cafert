@model CAFERT.Controllers.ManageChangePasswordViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><small>Settings / Security</small>Change Password</h1>
        <div class="crumbs"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a> / Security Settings</div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; background-color: rgba(25, 135, 84, 0.1); border-color: rgba(25, 135, 84, 0.2); color: #198754;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px; background-color: rgba(200, 85, 61, 0.1); border-color: rgba(200, 85, 61, 0.2); color: #c8553d;">
        <div asp-validation-summary="All"></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card-soft mb-4">
    <form asp-action="ManageChangePassword" method="post" class="form-card" autocomplete="off">
        @Html.AntiForgeryToken()

        <h2 class="serif-font mb-2" style="font-size: 1.5rem; color: var(--coffee);">Update Password</h2>
        <p class="text-muted mb-4" style="font-size: 0.9rem;">Change your current password to secure your admin account. Passwords must be at least 8 characters long.</p>

        <div class="row g-3">
            <div class="col-12 col-md-6 mb-3">
                <label class="form-label" asp-for="CurrentPassword">Current Password *</label>
                <input class="form-control" asp-for="CurrentPassword" type="password" required />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
        </div>
        
        <div class="row g-3">
            <div class="col-md-6 mb-3">
                <label class="form-label" asp-for="NewPassword">New Password *</label>
                <input class="form-control" asp-for="NewPassword" type="password" required />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            
            <div class="col-md-6 mb-3">
                <label class="form-label" asp-for="ConfirmNewPassword">Confirm New Password *</label>
                <input class="form-control" asp-for="ConfirmNewPassword" type="password" required />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-actions mt-4">
            <button type="submit" class="btn-fancy btn-save">
                <i class="bi bi-key-fill"></i> Update Password
            </button>
        </div>
    </form>
</div>
