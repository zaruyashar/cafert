@model CAFERT.Controllers.LoginViewModel
@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
    var refererUrl = ViewData["RefererUrl"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Cafert Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #fbf8f3;
            --cream-2: #f3ede2;
            --coffee: #2d2218;
            --coffee-2: #3d2f27;
            --caramel: #d4a85a;
            --olive: #5d5a3a;
            --muted: #9e8d75;
        }
        body {
            background: linear-gradient(135deg, var(--coffee-2) 0%, #17110c 100%);
            font-family: 'Jost', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: #2b231b;
        }
        .login-card {
            background: var(--cream);
            border: 1px solid rgba(212, 168, 90, 0.3);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        }
        .brand-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .bean-tile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            border-radius: 14px;
            background: linear-gradient(135deg, #3d2f27, #1f1610);
            border: 1px solid rgba(212, 168, 90, 0.4);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            margin-bottom: 12px;
        }
        .brand-text {
            font-family: 'Cormorant Garamond', serif;
            font-style: italic;
            font-weight: 600;
            font-size: 1.8rem;
            color: var(--coffee);
        }
        .brand-text b {
            font-style: normal;
            font-family: 'Jost', sans-serif;
            font-weight: 700;
            letter-spacing: .25em;
            text-transform: uppercase;
            font-size: 1.1rem;
            margin-left: 6px;
            background: linear-gradient(135deg, #a8804a 0%, #d4a85a 60%, #3d2f27 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--coffee);
            margin-bottom: 6px;
            letter-spacing: 0.03em;
        }
        .form-control {
            border-radius: 10px;
            border: 1px solid #e3d8c2;
            padding: 10px 14px;
            font-size: 0.95rem;
            background: #fff;
        }
        .form-control:focus {
            border-color: var(--caramel);
            box-shadow: 0 0 0 0.25rem rgba(200, 163, 122, 0.25);
        }
        .btn-coffee {
            background: linear-gradient(135deg, #5b4636 0%, #2d2218 100%);
            color: #fff;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            padding: 11px;
            transition: all 0.2s;
            letter-spacing: 0.05em;
        }
        .btn-coffee:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
            color: #fff;
            filter: brightness(1.1);
        }
        .btn-coffee:active {
            transform: translateY(0);
        }
        .auth-links {
            font-size: 0.85rem;
            text-align: center;
            margin-top: 20px;
        }
        .auth-links a {
            color: var(--caramel);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }
        .auth-links a:hover {
            color: #bfa068;
            text-decoration: underline;
        }
        .alert-custom {
            background-color: rgba(200, 85, 61, 0.1);
            border: 1px solid rgba(200, 85, 61, 0.2);
            color: #c8553d;
            border-radius: 10px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

<div class="login-card">
    <div class="brand-header">
        <span class="bean-tile"><span style="font-size: 1.6rem;">☕</span></span>
        <div class="brand-text"><i>the</i><b>cafert</b></div>
        <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem;">Sign in to access admin console</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-custom alert-dismissible fade show" role="alert">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <input type="hidden" name="refererUrl" value="@refererUrl" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" class="form-control" placeholder="admin@cafert.com" autocomplete="username" required />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <label asp-for="Password" class="form-label mb-0">Password</label>
                <a asp-action="VerifyEmail" class="small text-decoration-none" style="color: var(--caramel); font-size: 0.8rem;">Forgot password?</a>
            </div>
            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" required />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-4 form-check">
            <input asp-for="RememberMe" class="form-check-input" type="checkbox" style="border-color: #d4a85a;" />
            <label asp-for="RememberMe" class="form-check-label text-muted" style="font-size: 0.85rem; user-select: none;">
                Remember my session
            </label>
        </div>

        <button type="submit" class="btn btn-coffee w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
    </form>

    <div class="auth-links text-muted">
        Don't have an account? <a asp-action="Register">Register here</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
