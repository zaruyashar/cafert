@model List<CAFERT.Models.TeamMember>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Team Members";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><small>Content</small>Team Members</h1>
        <div class="crumbs"><a asp-action="Index">Dashboard</a> / Team</div>
    </div>
    <a asp-action="CreateTeamMember" class="btn-fancy btn-add" style="background: var(--coffee);">
        <i class="bi bi-person-plus-fill"></i> Add Team Member
    </a>
</div>

<div class="card-soft">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Bio</th>
                    <th>Sort Order</th>
                    <th class="text-end" style="padding-right: 24px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var member in Model)
                    {
                        <tr>
                            <td>#@member.Id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(member.PhotoUrl))
                                {
                                    <img src="@member.PhotoUrl" class="thumb" alt="@member.Name" />
                                }
                                else
                                {
                                    <div class="thumb d-flex align-items-center justify-content-center bg-light text-muted">
                                        <i class="bi bi-person" style="font-size: 1.25rem;"></i>
                                    </div>
                                }
                            </td>
                            <td><strong>@member.Name</strong></td>
                            <td><span class="badge-cat" style="background: var(--cream-2); color: var(--caramel-dk);">@member.Role</span></td>
                            <td><small class="text-muted d-block text-truncate" style="max-width: 300px;">@member.Bio</small></td>
                            <td>@member.SortOrder</td>
                            <td class="text-end" style="padding-right: 24px;">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="EditTeamMember" asp-route-id="@member.Id" class="btn-fancy btn-edit">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <form asp-action="DeleteTeamMember" asp-route-id="@member.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this team member?');" class="m-0">
                                        <button type="submit" class="btn-fancy btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-people-fill" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">No team members found. Click 'Add Team Member' to start.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
