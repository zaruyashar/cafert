@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><small>Overview</small>Admin Control Panel</h1>
        <div class="crumbs">Home / Dashboard</div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Menu items count card -->
    <div class="col-md-4">
        <div class="card-soft p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-uppercase text-secondary font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.1em;">Menu Items</span>
                    <i class="bi bi-journal-richtext text-warning" style="font-size: 2rem;"></i>
                </div>
                <h2 class="serif-font mb-2" style="font-size: 3rem;">@ViewBag.TotalMenuItems</h2>
                <p class="text-muted mb-0">Total dishes and drinks on the public menu.</p>
            </div>
            <div class="mt-4">
                <a asp-action="MenuItems" class="btn-fancy btn-add w-100 justify-content-center">
                    <i class="bi bi-gear-fill"></i> Manage Menu
                </a>
            </div>
        </div>
    </div>

    <!-- Featured count card -->
    <div class="col-md-4">
        <div class="card-soft p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-uppercase text-secondary font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.1em;">Featured Dishes</span>
                    <i class="bi bi-star-fill text-danger" style="font-size: 2rem;"></i>
                </div>
                <h2 class="serif-font mb-2" style="font-size: 3rem;">@ViewBag.FeaturedItemsCount</h2>
                <p class="text-muted mb-0">Highlighted dishes showing on the landing page.</p>
            </div>
            <div class="mt-4">
                <a asp-action="MenuItems" class="btn-fancy btn-edit w-100 justify-content-center" style="color: #fff !important;">
                    <i class="bi bi-star"></i> View Featured
                </a>
            </div>
        </div>
    </div>

    <!-- Team count card -->
    <div class="col-md-4">
        <div class="card-soft p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-uppercase text-secondary font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.1em;">Team Members</span>
                    <i class="bi bi-people-fill text-success" style="font-size: 2rem;"></i>
                </div>
                <h2 class="serif-font mb-2" style="font-size: 3rem;">@ViewBag.TotalTeamMembers</h2>
                <p class="text-muted mb-0">Active staff members and chefs.</p>
            </div>
            <div class="mt-4">
                <a asp-action="TeamMembers" class="btn-fancy btn-add w-100 justify-content-center" style="background: var(--coffee);">
                    <i class="bi bi-people"></i> Manage Team
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card-soft p-4 bg-white">
    <h3 class="serif-font mb-3">Quick Operations</h3>
    <div class="d-flex flex-wrap gap-3">
        <a asp-action="CreateMenuItem" class="btn-fancy btn-add">
            <i class="bi bi-plus-lg"></i> Add Menu Item
        </a>
        <a asp-action="CreateTeamMember" class="btn-fancy btn-add" style="background: var(--coffee);">
            <i class="bi bi-person-plus-fill"></i> Add Team Member
        </a>
        <a href="/" target="_blank" class="btn-ghost">
            <i class="bi bi-box-arrow-up-right"></i> Visit Public Site
        </a>
    </div>
</div>
