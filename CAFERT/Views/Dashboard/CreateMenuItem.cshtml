@model CAFERT.Models.MenuItem
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Menu Item";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><small>Menu / New</small>Add Menu Item</h1>
        <div class="crumbs"><a asp-action="Index">Dashboard</a> / <a asp-action="MenuItems">Menu</a> / Create</div>
    </div>
    <a asp-action="MenuItems" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back to list</a>
</div>

<div class="card-soft">
    <form asp-action="CreateMenuItem" method="post" class="form-card" autocomplete="off">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <h2 class="form-section-title">Item details</h2>
        <p class="form-section-sub">Fill in the dish information. Fields marked * are required.</p>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="Name">Name *</label>
                <input class="form-control" asp-for="Name" placeholder="e.g. Avocado Toast" required>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Category">Category *</label>
                <select class="form-select" asp-for="Category" required>
                    <option value="" disabled selected>Choose category…</option>
                    <option value="Breakfasts">Breakfasts</option>
                    <option value="Snacks">Snacks</option>
                    <option value="Mains">Mains</option>
                    <option value="Drinks">Drinks</option>
                    <option value="Desserts">Desserts</option>
                </select>
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <div>
                <label class="form-label" asp-for="Price">Price ($) *</label>
                <input class="form-control" type="number" step="0.01" asp-for="Price" placeholder="0.00" required>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label" asp-for="SortOrder">Sort order</label>
                <input class="form-control" type="number" asp-for="SortOrder" value="0">
                <div class="form-text">Lower numbers appear first on the public menu.</div>
                <span asp-validation-for="SortOrder" class="text-danger small"></span>
            </div>

            <div class="full">
                <label class="form-label" asp-for="Description">Description</label>
                <textarea class="form-control" asp-for="Description" placeholder="A short, mouth-watering description..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>

        <hr class="divider">
        <h2 class="form-section-title">Image & visibility</h2>
        <p class="form-section-sub">A square image works best (min. 600×600).</p>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="ImageUrl">Image URL</label>
                <input id="imgUrl" class="form-control" asp-for="ImageUrl" placeholder="https://...">
                <div class="form-text">Paste a web URL or an Unsplash image URL.</div>
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>

                <label class="form-label mt-4">Featured</label>
                <label class="switch-pill d-block">
                    <input class="form-check-input mt-0 me-2" type="checkbox" asp-for="IsFeatured">
                    <span>Show <strong>“Featured”</strong> badge and display on Home Page</span>
                </label>
            </div>
            <div>
                <label class="form-label">Preview</label>
                <div class="image-preview" id="preview"><i class="bi bi-image"></i></div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="MenuItems" class="btn-ghost">Cancel</a>
            <button type="submit" class="btn-fancy btn-save">
                <i class="bi bi-check2-circle"></i> Create item
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const imgUrl = document.getElementById('imgUrl');
        const preview = document.getElementById('preview');
        
        function updatePreview() {
            if (imgUrl && imgUrl.value) {
                preview.innerHTML = `<img src="${imgUrl.value}" style="width:100%;height:100%;object-fit:cover;" onerror="this.src='https://placehold.co/200?text=Invalid+Image'"/>`;
            } else {
                preview.innerHTML = `<i class="bi bi-image"></i>`;
            }
        }

        if (imgUrl && preview) {
            imgUrl.addEventListener('input', updatePreview);
            updatePreview();
        }
    </script>
}
