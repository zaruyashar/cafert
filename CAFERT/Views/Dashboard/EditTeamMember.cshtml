@model CAFERT.Models.TeamMember
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Team Member";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><small>Team / Edit</small>Edit Team Member</h1>
        <div class="crumbs"><a asp-action="Index">Dashboard</a> / <a asp-action="TeamMembers">Team</a> / Edit</div>
    </div>
    <a asp-action="TeamMembers" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back to list</a>
</div>

<div class="card-soft">
    <form asp-action="EditTeamMember" method="post" class="form-card" autocomplete="off">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <h2 class="form-section-title">Staff Details</h2>
        <p class="form-section-sub">Update the professional profile. Fields marked * are required.</p>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="Name">Full Name *</label>
                <input class="form-control" asp-for="Name" placeholder="e.g. Ray Stanley" required>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Role">Role / Position *</label>
                <input class="form-control" asp-for="Role" placeholder="e.g. Master Barista" required>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div>
                <label class="form-label" asp-for="SortOrder">Sort Order</label>
                <input class="form-control" type="number" asp-for="SortOrder">
                <div class="form-text">Lower numbers appear first on the public team page.</div>
                <span asp-validation-for="SortOrder" class="text-danger small"></span>
            </div>

            <div class="full">
                <label class="form-label" asp-for="Bio">Short Bio (1-2 sentences) *</label>
                <textarea class="form-control" asp-for="Bio" required></textarea>
                <span asp-validation-for="Bio" class="text-danger small"></span>
            </div>
        </div>

        <hr class="divider">
        <h2 class="form-section-title">Profile Photo</h2>
        <p class="form-section-sub">A portrait photo works best.</p>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="PhotoUrl">Photo URL</label>
                <input id="photoUrl" class="form-control" asp-for="PhotoUrl" placeholder="https://...">
                <div class="form-text">Paste a web URL or an Unsplash portrait URL.</div>
                <span asp-validation-for="PhotoUrl" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label">Preview</label>
                <div class="image-preview" id="preview" style="aspect-ratio: 4/5; max-width: 160px;"><i class="bi bi-person" style="font-size: 2.5rem;"></i></div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="TeamMembers" class="btn-ghost">Cancel</a>
            <button type="submit" class="btn-fancy btn-save" style="background: var(--grad-edit);">
                <i class="bi bi-check2-circle"></i> Save changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const photoUrl = document.getElementById('photoUrl');
        const preview = document.getElementById('preview');
        
        function updatePreview() {
            if (photoUrl && photoUrl.value) {
                preview.innerHTML = `<img src="${photoUrl.value}" style="width:100%;height:100%;object-fit:cover;" onerror="this.src='https://placehold.co/160x200?text=Invalid+Image'"/>`;
            } else {
                preview.innerHTML = `<i class="bi bi-person" style="font-size: 2.5rem;"></i>`;
            }
        }

        if (photoUrl && preview) {
            photoUrl.addEventListener('input', updatePreview);
            updatePreview();
        }
    </script>
}
