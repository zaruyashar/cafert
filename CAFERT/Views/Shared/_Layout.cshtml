<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The CAFERT</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Jost:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700&family=Raleway:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Bootstrap + Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CAFERT.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="public-header">
        <div class="container d-flex align-items-center justify-content-between py-3">
            <!-- Brand Logo -->
            <a class="brand-logo" asp-controller="Home" asp-action="Index">
                <span class="logo-italic">the</span>
                <span class="logo-bold">CAFERT</span>
            </a>

            <!-- Navigation Items (Exactly 3) -->
            <nav class="public-nav">
                <ul class="nav justify-content-center">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Menu" ? "active" : "")" asp-controller="Menu" asp-action="Index">Menu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Team" ? "active" : "")" asp-controller="Team" asp-action="Index">Team</a>
                    </li>
                </ul>
            </nav>

            <!-- Social Icons + Admin Link -->
            <div class="header-right d-flex align-items-center gap-3">
                <div class="social-icons d-none d-md-flex align-items-center gap-2">
                    <a href="https://facebook.com" class="social-icon"><i class="bi bi-facebook"></i></a>
                    <a href="https://x.com" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                    <a href="https://youtube.com" class="social-icon"><i class="bi bi-youtube"></i></a>
                </div>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-admin-pill" title="Admin Dashboard">
                    <i class="bi bi-shield-lock-fill"></i> <span class="d-none d-sm-inline">Admin</span>
                </a>
            </div>
        </div>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="public-footer text-center py-4 mt-5 border-top">
        <div class="container">
            <p class="footer-brand mb-2"><i>the</i><b>CAFERT</b></p>
            <p class="copyright mb-0">@DateTime.Now.Year &copy; | <a href="https://github.com/zaruyashar" target="_blank" rel="noopener noreferrer" class="text-decoration-none" style="color: floralwhite !important;">zaruyashar</a></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
